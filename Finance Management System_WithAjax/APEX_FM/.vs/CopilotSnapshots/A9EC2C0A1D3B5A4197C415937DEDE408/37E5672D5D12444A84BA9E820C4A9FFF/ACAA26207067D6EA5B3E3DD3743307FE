    using System.ComponentModel.DataAnnotations;
using System.ComponentModel.DataAnnotations.Schema;

namespace FinanceManagementSystem.Models
{
    public class Expense
    {
        [Key]
        public int ExpenseId { get; set; }

        // FK to user
        [Required]
        public int UserId { get; set; }

        // amount with decimal precision - EF precision will be configured in DbContext
        [Required]
        public decimal Amount { get; set; }

        // FK to category
        [Required]
        public int CategoryId { get; set; }

        [Require        [DataType(DataType.Date)]
        [NotInFutureDate(ErrorMessage = "Date cannot be in the future.")]
        public DateTime Date { get; set; }t; }

        public string? Description { get; set; }

        // navigation properties (nullable for creation convenience)
        public User? User { get; set; }
        public ExpenseCategory? Category { get; set; }
    }
}