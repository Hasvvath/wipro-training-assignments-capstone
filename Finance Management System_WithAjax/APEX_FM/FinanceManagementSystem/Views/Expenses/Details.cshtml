@model FinanceManagementSystem.Models.Expense
<h2>Expense Details</h2>
<dl class="row">
    <dt class="col-sm-2">User</dt>
    <dd class="col-sm-10">@Model.User?.Username</dd>
    <dt class="col-sm-2">Category</dt>
    <dd class="col-sm-10">@Model.Category?.CategoryName</dd>
    <dt class="col-sm-2">Amount</dt>
    <dd class="col-sm-10">₹@Model.Amount.ToString("0.00")</dd>
    <dt class="col-sm-2">Date</dt>
    <dd class="col-sm-10">@Model.Date.ToShortDateString()</dd>
    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Description</dd>
</dl>
<p><a class="btn btn-secondary" asp-action="Index">Back</a></p>
