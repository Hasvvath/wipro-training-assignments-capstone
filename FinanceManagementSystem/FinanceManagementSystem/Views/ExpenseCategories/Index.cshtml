@model IEnumerable<FinanceManagementSystem.Models.ExpenseCategory>

@{
    ViewData["Title"] = "Categories";
}

<h2>Categories</h2>

<p><a class="btn btn-primary" asp-action="Create">Add Category</a></p>

<table class="table">
    <thead><tr><th>Name</th><th></th></tr></thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.CategoryName</td>
                <td><a asp-action="Delete" asp-route-id="@c.CategoryId">Delete</a></td>
            </tr>
        }
    </tbody>
</table>